{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "description": "Automated dependency updates for gns3-mcp",

  "schedule": ["before 7am on Monday"],
  "timezone": "Europe/Paris",

  "packageRules": [
    {
      "description": "Group all Rust dependency updates into a single PR",
      "matchManagers": ["cargo"],
      "groupName": "rust dependencies",
      "automerge": false
    },
    {
      "description": "Auto-merge patch-level GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Pin rmcp to exact version — MCP SDK breaking changes are frequent",
      "matchPackageNames": ["rmcp"],
      "rangeStrategy": "pin"
    },
    {
      "description": "Security updates — raise priority and remove schedule restriction",
      "matchDatasources": ["crate"],
      "matchUpdateTypes": ["patch"],
      "prPriority": 10,
      "schedule": ["at any time"]
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },

  "commitMessagePrefix": "chore(deps):",
  "labels": ["dependencies"],
  "reviewers": ["btaoldai"]
}
